{
  "version": 2,
  "functions": {
    "dist/main.js": {
      "runtime": "nodejs20.x"
    }
  },
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["generated/prisma/**"] }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "dist/main.js" }]
}
